{
  "name": "codemind",
  "version": "0.1.0",
  "description": "Autonomous CLI coding agent",
  "type": "module",
  "bin": {
    "codemind": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "bun build src/cli.ts --outfile dist/cli.js --target bun",
    "db:migrate": "bunx prisma migrate dev",
    "db:generate": "bunx prisma generate",
    "db:studio": "bunx prisma studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "sandbox:build": "docker build -t codemind-sandbox src/sandbox/",
    "eval": "bun src/cli.ts eval",
    "test": "bun test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.86",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "ai": "^6.0.209",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "diff": "^9.0.0",
    "dockerode": "^5.0.0",
    "dotenv": "^17.4.2",
    "inquirer": "^14.0.2",
    "ollama-ai-provider": "^1.2.0",
    "ora": "^9.4.1",
    "prom-client": "^15.1.3",
    "tiktoken": "^1.0.22",
    "web-tree-sitter": "^0.26.9"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/dockerode": "^4.0.1",
    "@types/inquirer": "^9.0.10",
    "@types/node": "^26.0.0",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3"
  }
}
